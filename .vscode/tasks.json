{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Web Game Dev Server",
			"type": "shell",
			"command": "${workspaceFolder}\\.tools\\node-v24.18.0-win-x64\\npm.cmd",
			"args": [
				"run",
				"dev"
			],
			"options": {
				"env": {
					"Path": "${workspaceFolder}\\.tools\\node-v24.18.0-win-x64;${env:Path}",
					"PATH": "${workspaceFolder}\\.tools\\node-v24.18.0-win-x64;${env:PATH}"
				}
			},
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Web Game Dev Server + Chrome",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\run-dev-chrome.ps1",
				"-WorkspaceFolder",
				"${workspaceFolder}"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Shogi Online (Room + Dev)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\run-room-dev.ps1",
				"-WorkspaceFolder",
				"${workspaceFolder}"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Web Game Full Stack (Cloud + Room + Dev)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\scripts\\run-fullstack.ps1",
				"-WorkspaceFolder",
				"${workspaceFolder}"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Share Server (LAN/Internet)",
			"type": "shell",
			"command": "${workspaceFolder}\\.tools\\node-v24.18.0-win-x64\\npm.cmd",
			"args": [
				"run",
				"share"
			],
			"options": {
				"env": {
					"Path": "${workspaceFolder}\\.tools\\node-v24.18.0-win-x64;${env:Path}",
					"PATH": "${workspaceFolder}\\.tools\\node-v24.18.0-win-x64;${env:PATH}"
				}
			},
			"isBackground": true,
			"group": "build"
		}
	]
}