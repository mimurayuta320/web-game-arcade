    "dev:oneurl": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-next-nest-oneurl.ps1 -WorkspaceFolder .",
    "build:web": "npm --prefix apps/web run build",
    "build:api": "npm --prefix apps/api run build",
    "db:generate": "npm --prefix apps/api run prisma:generate",
