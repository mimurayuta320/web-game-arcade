    "dev:test": "vite --host 0.0.0.0 --port 5174 --strictPort",
    "dev:tofu": "vite --host toufugameshow.local --port 5173 --strictPort",
    "build": "vite build",
    "build:share": ".\\.tools\\node-v24.18.0-win-x64\\node.exe .\\node_modules\\vite\\bin\\vite.js build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "preview:test": "vite preview --host 0.0.0.0 --port 4174 --strictPort",
    "preview:tofu": "vite preview --host toufugameshow.local --port 4173 --strictPort",
    "serve:share": ".\\.tools\\node-v24.18.0-win-x64\\node.exe ./server/share-server.mjs",
    "serve:share:test": "set SHARE_PORT=4174&& set SHARE_DB_PATH=server\\data\\profiles.test.json&& set SHARE_CLOUD_API_BASE=http://127.0.0.1:18787&& .\\.tools\\node-v24.18.0-win-x64\\node.exe ./server/share-server.mjs",
    "share": ".\\.tools\\node-v24.18.0-win-x64\\node.exe .\\node_modules\\vite\\bin\\vite.js build && .\\.tools\\node-v24.18.0-win-x64\\node.exe ./server/share-server.mjs",
    "share:test": ".\\.tools\\node-v24.18.0-win-x64\\node.exe .\\node_modules\\vite\\bin\\vite.js build && set SHARE_PORT=4174&& set SHARE_DB_PATH=server\\data\\profiles.test.json&& set SHARE_CLOUD_API_BASE=http://127.0.0.1:18787&& .\\.tools\\node-v24.18.0-win-x64\\node.exe ./server/share-server.mjs",
    "cf:setup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\cloudflare\\setup-tunnel.ps1",
    "cf:run": "powershell -ExecutionPolicy Bypass -File .\\scripts\\cloudflare\\run-tunnel.ps1",
