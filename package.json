    "cloud": ".\\.tools\\node-v24.18.0-win-x64\\npm.cmd --prefix apps/api run start:cloud",
    "cloud:test": ".\\.tools\\node-v24.18.0-win-x64\\npm.cmd --prefix apps/api run start:cloud:test",
    "room": ".\\.tools\\node-v24.18.0-win-x64\\node.exe ./server/room-server.mjs",
    "room:test": "set ROOM_PORT=18788&& .\\.tools\\node-v24.18.0-win-x64\\node.exe ./server/room-server.mjs"
