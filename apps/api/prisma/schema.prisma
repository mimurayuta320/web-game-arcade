generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Score {
  id         Int      @id @default(autoincrement())
  playerName String
  score      Int
  game       String?
  createdAt  DateTime @default(now())
}
